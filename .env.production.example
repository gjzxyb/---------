# PostgreSQL 容器配置
POSTGRES_DB=teaching_evaluation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# 应用访问端口。若前面有 Nginx，通常保持 3000。
APP_PORT=3000

# 应用运行时环境变量
DATABASE_URL=postgresql://postgres:replace-with-a-strong-database-password@postgres:5432/teaching_evaluation?schema=public
NEXTAUTH_URL=https://pingjiao.example.com
NEXTAUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
REDIS_URL=redis://redis:6379
